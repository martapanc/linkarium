# Supabase
NEXT_PUBLIC_SUPABASE_URL=your-supabase-url
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_DEFAULT_KEY=your-supabase-key

# App
NEXT_PUBLIC_APP_URL=http://localhost:3637

# Rate limiting (requests per minute per IP for scraping)
SCRAPE_RATE_LIMIT=30

# Write access guard (server-only). Set to a strong secret passphrase.
# If unset, all write operations are blocked.
# Replace with real auth when accounts are implemented.
WRITE_SECRET=
